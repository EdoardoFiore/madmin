{
    "id": "wireguard",
    "name": "WireGuard VPN",
    "version": "1.4.0",
    "description": "WireGuard VPN instance and client management with firewall groups and multi-instance support",
    "author": "MADMIN Team",
    "system_dependencies": {
        "apt": [
            "wireguard",
            "wireguard-tools",
            "qrencode"
        ],
        "pip": [
            "qrcode>=7.3",
            "pillow>=9.0"
        ]
    },
    "database_migrations": [
        "migrations/001_initial.py"
    ],
    "install_hooks": {
        "post_install": "hooks/post_install.py",
        "on_disable": "hooks/on_disable.py"
    },
    "backend_router": "router.py",
    "static_dir": "static",
    "frontend_entry": "views/main.js",
    "permissions": [
        {
            "slug": "wireguard.view",
            "description": "Visualizza istanze WireGuard"
        },
        {
            "slug": "wireguard.manage",
            "description": "Crea/modifica istanze WireGuard"
        },
        {
            "slug": "wireguard.clients",
            "description": "Gestione client VPN"
        },
        {
            "slug": "wireguard.groups",
            "description": "Gestione gruppi firewall"
        }
    ],
    "menu": [
        {
            "label": "WireGuard",
            "icon": "https://www.svgrepo.com/show/520310/wireguard.svg",
            "route": "#wireguard"
        }
    ],
    "firewall_chains": [
        {
            "name": "MOD_WG_INPUT",
            "parent": "INPUT",
            "priority": 50
        },
        {
            "name": "MOD_WG_FORWARD",
            "parent": "FORWARD",
            "priority": 50
        },
        {
            "name": "MOD_WG_NAT",
            "parent": "POSTROUTING",
            "table": "nat",
            "priority": 50
        }
    ],
    "config_export": {
        "tables": [
            "wg_instance",
            "wg_client",
            "wg_group",
            "wg_group_member",
            "wg_group_rule"
        ],
        "irrecoverable_files": [],
        "post_restore": "hooks/post_restore.py"
    },
    "dashboard_widgets": [
        {
            "id": "vpn_status",
            "title": "WireGuard VPN",
            "col": 6,
            "permission": "wireguard.view"
        }
    ],
    "dependencies": []
}
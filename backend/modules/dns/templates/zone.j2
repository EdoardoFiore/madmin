; Zone file for {{ zone_name }}
; Generated by MADMIN DNS Module — do NOT edit manually
;
$TTL {{ ttl_default }}
@   IN  SOA {{ zone_name }}. admin.{{ zone_name }}. (
        {{ serial }}     ; Serial (YYYYMMDDNN)
        {{ soa_refresh }}        ; Refresh
        {{ soa_retry }}         ; Retry
        {{ soa_expire }}      ; Expire
        {{ soa_minimum }} )      ; Negative Cache TTL

; NS record
@   IN  NS  ns1.{{ zone_name }}.
ns1 IN  A   127.0.0.1

; Records
{% for rec in records %}
{% if rec.record_type == "A" %}
{{ "%-20s"|format(rec.name) }} {{ rec.ttl_str }}IN  A       {{ rec.value }}
{% elif rec.record_type == "AAAA" %}
{{ "%-20s"|format(rec.name) }} {{ rec.ttl_str }}IN  AAAA    {{ rec.value }}
{% elif rec.record_type == "CNAME" %}
{{ "%-20s"|format(rec.name) }} {{ rec.ttl_str }}IN  CNAME   {{ rec.value }}.
{% elif rec.record_type == "MX" %}
{{ "%-20s"|format(rec.name) }} {{ rec.ttl_str }}IN  MX      {{ rec.priority }} {{ rec.value }}.
{% elif rec.record_type == "TXT" %}
{{ "%-20s"|format(rec.name) }} {{ rec.ttl_str }}IN  TXT     "{{ rec.value }}"
{% elif rec.record_type == "SRV" %}
{{ "%-20s"|format(rec.name) }} {{ rec.ttl_str }}IN  SRV     {{ rec.priority }} {{ rec.weight }} {{ rec.port }} {{ rec.value }}.
{% elif rec.record_type == "NS" %}
{{ "%-20s"|format(rec.name) }} {{ rec.ttl_str }}IN  NS      {{ rec.value }}.
{% elif rec.record_type == "PTR" %}
{{ "%-20s"|format(rec.name) }} {{ rec.ttl_str }}IN  PTR     {{ rec.value }}.
{% endif %}
{% endfor %}

// BIND9 Options - generated by MADMIN DNS Module
// Do NOT edit manually - changes will be overwritten

options {
    directory "/var/cache/bind";

    // Listening interfaces
{% if listen_addresses %}
    listen-on { {{ listen_addresses }} };
{% else %}
    listen-on { any; };
{% endif %}
    listen-on-v6 { none; };

    // Query ACL
    allow-query { {{ allow_query }}; };

{% if mode == "recursive" %}
    // Recursive mode — resolve locally first, then forward
    recursion yes;
{% if forwarders %}
    forwarders {
{% for fw in forwarders %}
        {{ fw }};
{% endfor %}
    };
    forward first;
{% endif %}
{% elif mode == "forward_only" %}
    // Forward-only mode — forward all queries to upstream
    recursion yes;
{% if forwarders %}
    forwarders {
{% for fw in forwarders %}
        {{ fw }};
{% endfor %}
    };
    forward only;
{% endif %}
{% elif mode == "non_recursive" %}
    // Non-recursive mode — local zones only, no forwarding
    recursion no;
{% endif %}

    // DNSSEC
{% if dnssec_validation %}
    dnssec-validation auto;
{% else %}
    dnssec-validation no;
{% endif %}

    // Security
    allow-transfer { none; };
    auth-nxdomain no;
    version "not disclosed";
};

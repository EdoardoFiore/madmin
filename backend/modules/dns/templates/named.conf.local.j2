// BIND9 Local Zones - generated by MADMIN DNS Module
// Do NOT edit manually - changes will be overwritten

{% for zone in zones %}
{% if zone.zone_type == "master" %}
zone "{{ zone.name }}" {
    type master;
    file "/etc/bind/zones/db.{{ zone.name }}";
    allow-update { none; };
};

{% elif zone.zone_type == "forward" %}
zone "{{ zone.name }}" {
    type forward;
    forward only;
{% if zone.forward_servers_list %}
    forwarders {
{% for srv in zone.forward_servers_list %}
        {{ srv }};
{% endfor %}
    };
{% endif %}
};

{% elif zone.zone_type == "stub" %}
zone "{{ zone.name }}" {
    type stub;
{% if zone.forward_servers_list %}
    masters {
{% for srv in zone.forward_servers_list %}
        {{ srv }};
{% endfor %}
    };
{% endif %}
};

{% endif %}
{% endfor %}

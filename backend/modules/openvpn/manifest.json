{
    "id": "openvpn",
    "name": "OpenVPN Manager",
    "version": "1.1.2",
    "description": "OpenVPN server and client management with PKI, certificate generation, and multi-instance support",
    "author": "MADMIN Team",
    "system_dependencies": {
        "apt": [
            "openvpn",
            "easy-rsa"
        ],
        "pip": [
            "qrcode>=7.3"
        ]
    },
    "database_migrations": [
        "migrations/001_initial.py"
    ],
    "install_hooks": {
        "post_install": "hooks/post_install.py",
        "on_disable": "hooks/on_disable.py"
    },
    "backend_router": "router.py",
    "static_dir": "static",
    "frontend_entry": "views/main.js",
    "permissions": [
        {
            "slug": "openvpn.view",
            "description": "Visualizza istanze OpenVPN"
        },
        {
            "slug": "openvpn.manage",
            "description": "Crea/modifica istanze OpenVPN"
        },
        {
            "slug": "openvpn.clients",
            "description": "Gestione client VPN"
        },
        {
            "slug": "openvpn.groups",
            "description": "Gestione gruppi firewall"
        }
    ],
    "menu": [
        {
            "label": "OpenVPN",
            "icon": "https://www.svgrepo.com/show/504696/openvpn.svg",
            "route": "#openvpn"
        }
    ],
    "firewall_chains": [
        {
            "name": "MOD_OVPN_INPUT",
            "parent": "INPUT",
            "priority": 50
        },
        {
            "name": "MOD_OVPN_FORWARD",
            "parent": "FORWARD",
            "priority": 50
        },
        {
            "name": "MOD_OVPN_NAT",
            "parent": "POSTROUTING",
            "table": "nat",
            "priority": 50
        }
    ],
    "config_export": {
        "tables": [
            "ovpn_instance",
            "ovpn_client",
            "ovpn_group",
            "ovpn_group_member",
            "ovpn_group_rule"
        ],
        "irrecoverable_files": [
            "/etc/openvpn/server/*/*.crt",
            "/etc/openvpn/server/*/*.key",
            "/etc/openvpn/server/*/*.pem",
            "/etc/openvpn/server/*/easy-rsa"
        ],
        "post_restore": "hooks/post_restore.py"
    },
    "dependencies": []
}